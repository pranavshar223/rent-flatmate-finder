<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{subject}}</title>
  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: #f4f4f5;
      margin: 0;
      padding: 0;
      color: #18181b;
    }
    .email-container {
      max-width: 600px;
      margin: 40px auto;
      background-color: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    .content {
      padding: 32px;
    }
    .content h1 {
      font-size: 24px;
      font-weight: 700;
      margin-top: 0;
      color: #09090b;
    }
    .content p {
      font-size: 16px;
      line-height: 1.6;
      color: #3f3f46;
    }
    .btn {
      display: inline-block;
      padding: 12px 24px;
      background-color: #4f46e5;
      color: #ffffff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
      margin-top: 16px;
    }
    .btn:hover {
      background-color: #4338ca;
    }
    .highlight-box {
      background-color: #f3f4f6;
      border-left: 4px solid #4f46e5;
      padding: 16px;
      margin: 24px 0;
      border-radius: 0 8px 8px 0;
    }
    .highlight-box ul {
      margin: 0;
      padding-left: 20px;
      color: #3f3f46;
    }
  </style>
</head>
<body>
  <div class="email-container">
    {{> header}}
    
    <div class="content">
      {{{body}}}
    </div>
    
    {{> footer}}
  </div>
</body>
</html>
